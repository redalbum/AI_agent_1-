# Строка подключения к базе 1С (скрипты сборки и run-com.ps1 / python -m com_1c)
# Скрипты сборки и COM-подключение запускайте от имени администратора.
# Скопируйте в .env и отредактируйте под свою базу.
# Файловая база:
1C_CONNECTION_STRING=File="D:\EDT_base\КонфигурацияТест";
# Серверная база (пример):
# 1C_CONNECTION_STRING=Srvr=server;Ref=base;Usr=user;Pwd=pass;

# Пути к платформам 1С (build_extension_83.py, update_1c.py)
PLATFORM_83=C:\Program Files\1cv8\8.3.27.1859\bin\1cv8.exe
PLATFORM_85=C:\Program Files\1cv8\8.5.1.1150\bin\1cv8.exe

# LLM Provider (Gitsell, OpenRouter, OpenAI или любой OpenAI-совместимый)
# Примеры:
#   Gitsell:    PROVIDER_BASE_URL=https://gitsell.ru/api/v1
#   OpenRouter: PROVIDER_BASE_URL=https://openrouter.ai/api/v1
#   OpenAI:     PROVIDER_BASE_URL=https://api.openai.com/v1
PROVIDER_BASE_URL=https://openrouter.ai/api/v1
PROVIDER_API_KEY=sk-or-v1-your-api-key-here
# Примеры моделей для OpenRouter: deepseek/deepseek-chat, google/gemini-2.0-flash-exp:free, anthropic/claude-3.5-sonnet
PROVIDER_MODEL=deepseek/deepseek-chat

# OpenRouter specific (опционально, используется для идентификации приложения)
# Подробнее: https://openrouter.ai/docs#headers
OPENROUTER_REFERER=https://your-app.com
OPENROUTER_TITLE=1C AI Agent

# 1C Connection (для com_1c / run_dialog.py)
ONEC_CONNECTION_STRING=
ONEC_USER=Администратор
ONEC_PASSWORD=

# Уведомления в Telegram (test_examples.py)
# Создайте бота через @BotFather, получите chat_id через @userinfobot
TELEGRAM_BOT_TOKEN=__PASTE_TELEGRAM_BOT_TOKEN__
TELEGRAM_CHAT_ID=__PASTE_TELEGRAM_CHAT_ID__
TELEGRAM_DEBUG=0

# Внешний LLM для scoring в test_examples.py (--score-mode llm|hybrid)
# OpenAI-compatible endpoint, обычно .../v1/chat/completions
SCORE_LLM_API_URL=__PASTE_SCORE_LLM_API_URL__
SCORE_LLM_API_KEY=__PASTE_SCORE_LLM_API_KEY__
SCORE_LLM_MODEL=__PASTE_SCORE_LLM_MODEL__
SCORE_LLM_TIMEOUT=30
