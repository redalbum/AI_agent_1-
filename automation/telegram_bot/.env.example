# ═══════════════════════════════════════════════════════════════
#  🤖 AI Бизнес-Ассистент для 1С — Настройки
# ═══════════════════════════════════════════════════════════════
#
#  После заполнения сохраните файл как .env (уберите .example)
#


# ───────────────────────────────────────────────────────────────
#  TELEGRAM
# ───────────────────────────────────────────────────────────────

# Токен бота — получите у @BotFather в Telegram
# 1. Откройте @BotFather → /newbot → придумайте имя
# 2. Скопируйте токен вида 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=

# Ваш Telegram ID — узнайте у @userinfobot или @getmyid_bot
# Напишите боту /start и он покажет ваш ID (только цифры)
# Можно указать несколько через запятую: 123456789,987654321
TELEGRAM_ALLOWED_USERS=


# ───────────────────────────────────────────────────────────────
#  1С:ПРЕДПРИЯТИЕ
# ───────────────────────────────────────────────────────────────

# Путь к папке с базой 1С (файловая база)
# Пример: C:\Bases\Розница или D:\1C\МояБаза
ONEC_BASE_PATH=C:\Bases\Retail

# Имя пользователя 1С (оставьте пустым если входите без пароля)
ONEC_USER=

# Пароль пользователя 1С (оставьте пустым если нет пароля)
ONEC_PASSWORD=


# ───────────────────────────────────────────────────────────────
#  ИСКУССТВЕННЫЙ ИНТЕЛЛЕКТ (OpenRouter)
# ───────────────────────────────────────────────────────────────

# API-ключ OpenRouter — получите на https://openrouter.ai/keys
# 1. Зарегистрируйтесь на openrouter.ai
# 2. Перейдите в Keys → Create Key
# 3. Скопируйте ключ вида sk-or-v1-...
OPENROUTER_API_KEY=

# Модель ИИ (можно не менять, по умолчанию — Claude)
# Другие модели: openai/gpt-4o, google/gemini-pro
OPENROUTER_MODEL=anthropic/claude-sonnet-4


# ───────────────────────────────────────────────────────────────
#  ДОПОЛНИТЕЛЬНО (можно не трогать)
# ───────────────────────────────────────────────────────────────

# Как часто обновлять информацию о структуре базы 1С (в часах)
METADATA_CACHE_HOURS=24
