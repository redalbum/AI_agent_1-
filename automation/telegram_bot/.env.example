# ═══════════════════════════════════════════════════════════════
#  🤖 AI Бизнес-Ассистент для 1С:Розница 2.3 — Настройки
#
#  Этот файл является шаблоном.
#  Скопируйте его в .env и заполните реальными значениями.
#  Или запустите FULL_INSTALL.bat — он заполнит всё автоматически.
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# TELEGRAM
# ─────────────────────────────────────────────────────────────────
# Токен бота от @BotFather (обязательно)
# Как получить: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=ваш_токен

# ID пользователей через запятую, которым разрешён доступ
# Узнать свой ID: напишите @userinfobot в Telegram
TELEGRAM_ALLOWED_USERS=123456789,987654321

# ─────────────────────────────────────────────────────────────────
# 1С:Розница 2.3
# ─────────────────────────────────────────────────────────────────
# Строка подключения к базе 1С
# Файловая база:  File="C:\Bases\Retail";
# Серверная база: Srvr="192.168.1.100";Ref="retail";
# Строка может включать учётные данные:
#   File="C:\Bases\Retail";Usr="Администратор";Pwd="пароль";
ONEC_CONNECTION_STRING=File="C:\Bases\Retail";

# Логин пользователя 1С (если не включён в строку подключения)
ONEC_USERNAME=

# Пароль пользователя 1С (если не включён в строку подключения)
ONEC_PASSWORD=

# ─────────────────────────────────────────────────────────────────
# LLM (OpenRouter)
# ─────────────────────────────────────────────────────────────────
# API ключ от openrouter.ai (обязательно)
# Получить: https://openrouter.ai → Account → API Keys
PROVIDER_API_KEY=sk-or-v1-ваш_ключ

# Модель LLM (рекомендуется anthropic/claude-3.5-sonnet)
# Альтернативы: openai/gpt-4o-mini, google/gemini-pro
LLM_MODEL=anthropic/claude-3.5-sonnet

# ─────────────────────────────────────────────────────────────────
# ДОПОЛНИТЕЛЬНО
# ─────────────────────────────────────────────────────────────────
# Время кэширования метаданных 1С в секундах (по умолчанию 3600)
METADATA_CACHE_TTL=3600

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
