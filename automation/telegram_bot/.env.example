# ===============================================================
#    AI Бизнес-Ассистент для 1С — Настройки
# ===============================================================

# ---------------------------------------------------------------
# TELEGRAM
# ---------------------------------------------------------------

# Токен бота (получить у @BotFather в Telegram)
# Инструкция: напиши /newbot, придумай имя, скопируй токен
TELEGRAM_BOT_TOKEN=вставь-токен-сюда

# Твой Telegram ID (чтобы только ты мог использовать бота)
# Узнать: напиши @userinfobot → скопируй число из "Id:"
# Можно несколько через запятую: 123456789,987654321
TELEGRAM_ALLOWED_USERS=вставь-свой-id

# ---------------------------------------------------------------
# 1С
# ---------------------------------------------------------------

# Строка подключения к базе 1С
# Как узнать путь:
#   1. Открой список баз 1С
#   2. Выбери нужную базу
#   3. Нажми "Изменить"
#   4. Скопируй путь из поля "Каталог информационной базы"
# Пример: File="C:\Users\Иван\Documents\1C\RetailBase";
ONEC_CONNECTION_STRING=File="C:\путь\к\базе\1С";

# Пользователь 1С (обычно Администратор)
ONEC_USER=Администратор

# Пароль пользователя 1С (оставь пустым если нет пароля)
ONEC_PASSWORD=

# ---------------------------------------------------------------
# LLM (Искусственный интеллект)
# ---------------------------------------------------------------

# OpenRouter — универсальный доступ к разным моделям ИИ
# Регистрация: https://openrouter.ai (бесплатно)
# После регистрации: Keys → Create Key → скопируй ключ

PROVIDER_BASE_URL=https://openrouter.ai/api/v1
PROVIDER_API_KEY=вставь-ключ-openrouter

# Модель ИИ (рекомендуемые):
# - deepseek/deepseek-chat (быстрая и дешёвая)
# - google/gemini-2.0-flash-exp:free (бесплатная!)
# - anthropic/claude-3.5-sonnet (самая умная, дороже)
PROVIDER_MODEL=deepseek/deepseek-chat

# ---------------------------------------------------------------
# ДОПОЛНИТЕЛЬНО (можно не менять)
# ---------------------------------------------------------------

# Файл кеша метаданных (бот запомнит структуру базы)
METADATA_CACHE_FILE=metadata_cache.json

# Время жизни кеша в часах (потом пересканирует базу)
METADATA_CACHE_TTL_HOURS=24

# Логирование (DEBUG для отладки, INFO для обычной работы)
LOG_LEVEL=INFO
