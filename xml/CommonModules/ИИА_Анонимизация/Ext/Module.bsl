#Область ПрограммныйИнтерфейс

// Анонимизирует текст перед отправкой в LLM
//
// Параметры:
//  Текст - Строка - исходный текст
//  НастройкиАнонимизации - Структура - (опционально) настройки анонимизации
//
// Возвращаемое значение:
//  Строка - анонимизированный текст
//
Функция АнонимизироватьТекст(Знач Текст, НастройкиАнонимизации = Неопределено) Экспорт
    
    Если ПустаяСтрока(Текст) Тогда
        Возврат "";
    КонецЕсли;
    
    Результат = Текст;
    
    // Получаем настройки
    Настройки = ПолучитьНастройкиАнонимизации(НастройкиАнонимизации);
    
    // Анонимизируем по категориям
    Если Настройки.АнонимизироватьИНН Тогда
        Результат = АнонимизироватьИНН(Результат);
    КонецЕсли;
    
    Если Настройки.АнонимизироватьКПП Тогда
        Результат = АнонимизироватьКПП(Результат);
    КонецЕсли;
    
    Если Настройки.АнонимизироватьОГРН Тогда
        Результат = АнонимизироватьОГРН(Результат);
    КонецЕсли;
    
    Если Настройки.АнонимизироватьТелефоны Тогда
        Результат = АнонимизироватьТелефоны(Результат);
    КонецЕсли;
    
    Если Настройки.АнонимизироватьEmail Тогда
        Результат = АнонимизироватьEmail(Результат);
    КонецЕсли;
    
    Если Настройки.АнонимизироватьБанковскиеРеквизиты Тогда
        Результат = АнонимизироватьБанковскиеРеквизиты(Результат);
    КонецЕсли;
    
    Если Настройки.АнонимизироватьПаспортныеДанные Тогда
        Результат = АнонимизироватьПаспортныеДанные(Результат);
    КонецЕсли;
    
    Если Настройки.АнонимизироватьСНИЛС Тогда
        Результат = АнонимизироватьСНИЛС(Результат);
    КонецЕсли;
    
    Возврат Результат;
    
КонецФункции

// Проверяет, включена ли анонимизация
//
// Возвращаемое значение:
//  Булево - Истина, если анонимизация включена
//
Функция АнонимизацияВключена() Экспорт
    
    // TODO: Добавить проверку настройки из регистра ИИА_НастройкиПользователей
    // Пока по умолчанию включена
    Возврат Истина;
    
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедуры

Функция ПолучитьНастройкиАнонимизации(ВходныеНастройки)
    
    Настройки = Новый Структура;
    Настройки.Вставить("АнонимизироватьИНН", Истина);
    Настройки.Вставить("АнонимизироватьКПП", Истина);
    Настройки.Вставить("АнонимизироватьОГРН", Истина);
    Настройки.Вставить("АнонимизироватьТелефоны", Истина);
    Настройки.Вставить("АнонимизироватьEmail", Истина);
    Настройки.Вставить("АнонимизироватьБанковскиеРеквизиты", Истина);
    Настройки.Вставить("АнонимизироватьПаспортныеДанные", Истина);
    Настройки.Вставить("АнонимизироватьСНИЛС", Истина);
    
    Если ВходныеНастройки <> Неопределено И ТипЗнч(ВходныеНастройки) = Тип("Структура") Тогда
        Для Каждого КлючЗначение Из ВходныеНастройки Цикл
            Если Настройки.Свойство(КлючЗначение.Ключ) Тогда
                Настройки.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
            КонецЕсли;
        КонецЦикла;
    КонецЕсли;
    
    Возврат Настройки;
    
КонецФункции

// Анонимизирует ИНН (10 или 12 цифр)
Функция АнонимизироватьИНН(Знач Текст)
    
    // Паттерны ИНН: 10 цифр (юрлицо) или 12 цифр (физлицо)
    // Ищем контекст: "ИНН", "инн", "ИНН:", "ИНН " и т.д.
    
    Результат = Текст;
    
    // ИНН юрлица (10 цифр)
    Результат = ЗаменитьПоПаттерну(Результат, "ИНН[:\s]*(\d{10})(?!\d)", "ИНН: ***СКРЫТО***");
    Результат = ЗаменитьПоПаттерну(Результат, "инн[:\s]*(\d{10})(?!\d)", "ИНН: ***СКРЫТО***");
    
    // ИНН физлица (12 цифр)
    Результат = ЗаменитьПоПаттерну(Результат, "ИНН[:\s]*(\d{12})(?!\d)", "ИНН: ***СКРЫТО***");
    Результат = ЗаменитьПоПаттерну(Результат, "инн[:\s]*(\d{12})(?!\d)", "ИНН: ***СКРЫТО***");
    
    // Просто последовательность 10-12 цифр рядом со словом ИНН
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "ИНН", 10, 12, "***СКРЫТО***");
    
    Возврат Результат;
    
КонецФункции

// Анонимизирует КПП (9 цифр)
Функция АнонимизироватьКПП(Знач Текст)
    
    Результат = Текст;
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "КПП", 9, 9, "***СКРЫТО***");
    
    Возврат Результат;
    
КонецФункции

// Анонимизирует ОГРН (13 или 15 цифр)
Функция АнонимизироватьОГРН(Знач Текст)
    
    Результат = Текст;
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "ОГРН", 13, 15, "***СКРЫТО***");
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "ОГРНИП", 15, 15, "***СКРЫТО***");
    
    Возврат Результат;
    
КонецФункции

// Анонимизирует телефонные номера
Функция АнонимизироватьТелефоны(Знач Текст)
    
    Результат = Текст;
    
    // +7 (XXX) XXX-XX-XX или 8 (XXX) XXX-XX-XX
    Результат = ЗаменитьТелефонныйНомер(Результат);
    
    Возврат Результат;
    
КонецФункции

// Анонимизирует email адреса
Функция АнонимизироватьEmail(Знач Текст)
    
    Результат = Текст;
    
    // Простой поиск email паттерна
    Позиция = 1;
    Пока Позиция <= СтрДлина(Результат) Цикл
        ПозицияСобаки = СтрНайти(Результат, "@", , Позиция);
        Если ПозицияСобаки = 0 Тогда
            Прервать;
        КонецЕсли;
        
        // Ищем начало email (до @)
        НачалоEmail = ПозицияСобаки;
        Пока НачалоEmail > 1 Цикл
            Символ = Сред(Результат, НачалоEmail - 1, 1);
            Если НЕ ЭтоСимволEmail(Символ) Тогда
                Прервать;
            КонецЕсли;
            НачалоEmail = НачалоEmail - 1;
        КонецЦикла;
        
        // Ищем конец email (после @)
        КонецEmail = ПозицияСобаки;
        Пока КонецEmail < СтрДлина(Результат) Цикл
            Символ = Сред(Результат, КонецEmail + 1, 1);
            Если НЕ ЭтоСимволEmail(Символ) И Символ <> "." Тогда
                Прервать;
            КонецЕсли;
            КонецEmail = КонецEmail + 1;
        КонецЦикла;
        
        Если КонецEmail > ПозицияСобаки И НачалоEmail < ПозицияСобаки Тогда
            ИсходныйEmail = Сред(Результат, НачалоEmail, КонецEmail - НачалоEmail + 1);
            Если СтрДлина(ИсходныйEmail) >= 5 Тогда // минимум a@b.c
                Результат = Лев(Результат, НачалоEmail - 1) + "***@***.***" + Сред(Результат, КонецEmail + 1);
            КонецЕсли;
        КонецЕсли;
        
        Позиция = НачалоEmail + 12; // длина "***@***.***"
    КонецЦикла;
    
    Возврат Результат;
    
КонецФункции

// Анонимизирует банковские реквизиты (р/с, к/с, БИК)
Функция АнонимизироватьБанковскиеРеквизиты(Знач Текст)
    
    Результат = Текст;
    
    // Расчётный счёт (20 цифр)
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "Р/С", 20, 20, "***СКРЫТО***");
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "р/с", 20, 20, "***СКРЫТО***");
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "Расчётный счёт", 20, 20, "***СКРЫТО***");
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "Расчетный счет", 20, 20, "***СКРЫТО***");
    
    // Корреспондентский счёт (20 цифр)
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "К/С", 20, 20, "***СКРЫТО***");
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "к/с", 20, 20, "***СКРЫТО***");
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "Корр. счёт", 20, 20, "***СКРЫТО***");
    
    // БИК (9 цифр)
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "БИК", 9, 9, "***СКРЫТО***");
    
    Возврат Результат;
    
КонецФункции

// Анонимизирует паспортные данные
Функция АнонимизироватьПаспортныеДанные(Знач Текст)
    
    Результат = Текст;
    
    // Серия и номер паспорта (XX XX XXXXXX)
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "Паспорт", 4, 10, "***СКРЫТО***");
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "паспорт", 4, 10, "***СКРЫТО***");
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "Серия", 2, 4, "***");
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "Номер", 6, 6, "***СКРЫТО***");
    
    Возврат Результат;
    
КонецФункции

// Анонимизирует СНИЛС (XXX-XXX-XXX XX)
Функция АнонимизироватьСНИЛС(Знач Текст)
    
    Результат = Текст;
    Результат = ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Результат, "СНИЛС", 11, 14, "***-***-*** **");
    
    Возврат Результат;
    
КонецФункции

// Вспомогательная функция: заменяет числовую последовательность рядом с ключевым словом
Функция ЗаменитьЧисловуюПоследовательностьРядомСоСловом(Знач Текст, КлючевоеСлово, МинДлина, МаксДлина, Замена)
    
    Результат = Текст;
    ДлинаКлюча = СтрДлина(КлючевоеСлово);
    
    Позиция = СтрНайти(ВРег(Результат), ВРег(КлючевоеСлово));
    Пока Позиция > 0 Цикл
        
        // Ищем числовую последовательность после ключевого слова
        НачалоПоиска = Позиция + ДлинаКлюча;
        НачалоЧисел = 0;
        
        // Пропускаем разделители (пробелы, двоеточия)
        Для Индекс = НачалоПоиска По Мин(НачалоПоиска + 10, СтрДлина(Результат)) Цикл
            Символ = Сред(Результат, Индекс, 1);
            Если ЭтоЦифра(Символ) Тогда
                НачалоЧисел = Индекс;
                Прервать;
            ИначеЕсли НЕ (Символ = " " ИЛИ Символ = ":" ИЛИ Символ = "	") Тогда
                Прервать;
            КонецЕсли;
        КонецЦикла;
        
        Если НачалоЧисел > 0 Тогда
            // Собираем числовую последовательность (включая дефисы и пробелы)
            КонецЧисел = НачалоЧисел;
            КоличествоЦифр = 0;
            Для Индекс = НачалоЧисел По СтрДлина(Результат) Цикл
                Символ = Сред(Результат, Индекс, 1);
                Если ЭтоЦифра(Символ) Тогда
                    КоличествоЦифр = КоличествоЦифр + 1;
                    КонецЧисел = Индекс;
                ИначеЕсли Символ = "-" ИЛИ Символ = " " Тогда
                    КонецЧисел = Индекс;
                Иначе
                    Прервать;
                КонецЕсли;
            КонецЦикла;
            
            Если КоличествоЦифр >= МинДлина И КоличествоЦифр <= МаксДлина Тогда
                Результат = Лев(Результат, НачалоЧисел - 1) + Замена + Сред(Результат, КонецЧисел + 1);
            КонецЕсли;
        КонецЕсли;
        
        СледующаяПозиция = СтрНайти(ВРег(Результат), ВРег(КлючевоеСлово), , Позиция + 1);
        Если СледующаяПозиция = 0 ИЛИ СледующаяПозиция = Позиция Тогда
            Прервать;
        КонецЕсли;
        Позиция = СледующаяПозиция;
        
    КонецЦикла;
    
    Возврат Результат;
    
КонецФункции

// Заменяет телефонные номера
Функция ЗаменитьТелефонныйНомер(Знач Текст)
    
    Результат = Текст;
    
    // Паттерн: +7 или 8, затем 10 цифр (с возможными скобками, пробелами, дефисами)
    Позиция = 1;
    Пока Позиция <= СтрДлина(Результат) Цикл
        
        // Ищем начало телефона (+7 или 8)
        ПозицияПлюс = СтрНайти(Результат, "+7", , Позиция);
        ПозицияВосемь = СтрНайти(Результат, "8(", , Позиция);
        Если ПозицияВосемь = 0 Тогда
            ПозицияВосемь = СтрНайти(Результат, "8 (", , Позиция);
        КонецЕсли;
        
        НачалоТелефона = 0;
        Если ПозицияПлюс > 0 И (ПозицияВосемь = 0 ИЛИ ПозицияПлюс < ПозицияВосемь) Тогда
            НачалоТелефона = ПозицияПлюс;
        ИначеЕсли ПозицияВосемь > 0 Тогда
            НачалоТелефона = ПозицияВосемь;
        Иначе
            Прервать;
        КонецЕсли;
        
        // Собираем телефонный номер (до 20 символов после начала)
        КоличествоЦифр = 0;
        КонецТелефона = НачалоТелефона;
        Для Индекс = НачалоТелефона По Мин(НачалоТелефона + 20, СтрДлина(Результат)) Цикл
            Символ = Сред(Результат, Индекс, 1);
            Если ЭтоЦифра(Символ) Тогда
                КоличествоЦифр = КоличествоЦифр + 1;
                КонецТелефона = Индекс;
            ИначеЕсли Символ = "+" ИЛИ Символ = "(" ИЛИ Символ = ")" ИЛИ Символ = "-" ИЛИ Символ = " " Тогда
                КонецТелефона = Индекс;
            Иначе
                Прервать;
            КонецЕсли;
        КонецЦикла;
        
        Если КоличествоЦифр >= 10 Тогда
            Результат = Лев(Результат, НачалоТелефона - 1) + "+7-***-***-**-**" + Сред(Результат, КонецТелефона + 1);
            Позиция = НачалоТелефона + 16;
        Иначе
            Позиция = НачалоТелефона + 1;
        КонецЕсли;
        
    КонецЦикла;
    
    Возврат Результат;
    
КонецФункции

Функция ЗаменитьПоПаттерну(Знач Текст, Паттерн, Замена)
    // Упрощённая замена без полноценных регулярных выражений
    // В 1С нет встроенной поддержки regex, поэтому используем другие методы
    Возврат Текст;
КонецФункции

Функция ЭтоЦифра(Символ)
    Возврат Символ >= "0" И Символ <= "9";
КонецФункции

Функция ЭтоСимволEmail(Символ)
    Возврат (Символ >= "a" И Символ <= "z") 
        ИЛИ (Символ >= "A" И Символ <= "Z")
        ИЛИ (Символ >= "0" И Символ <= "9")
        ИЛИ Символ = "_"
        ИЛИ Символ = "-"
        ИЛИ Символ = ".";
КонецФункции

#КонецОбласти
