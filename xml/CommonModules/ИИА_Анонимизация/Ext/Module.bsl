#Область ПрограммныйИнтерфейс

// Токенизирует текст с сохранением маппинга для обратного восстановления
//
// Параметры:
//  Текст - Строка - исходный текст
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог для сохранения маппинга
//
// Возвращаемое значение:
//  Структура:
//    ТокенизированныйТекст - Строка - текст с токенами вместо реальных данных
//    Маппинг - Соответствие - маппинг токен -> исходное значение
//
Функция ТокенизироватьТекст(Знач Текст, СсылкаДиалога = Неопределено) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ТокенизированныйТекст", Текст);
	Результат.Вставить("Маппинг", Новый Соответствие);
	
	Если ПустаяСтрока(Текст) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ТекущийТекст = Текст;
	Маппинг = Новый Соответствие;
	Счётчики = Новый Структура;
	Счётчики.Вставить("КОНТР", 0);
	Счётчики.Вставить("ИНН", 0);
	Счётчики.Вставить("КПП", 0);
	Счётчики.Вставить("ОГРН", 0);
	Счётчики.Вставить("ТЕЛ", 0);
	Счётчики.Вставить("EMAIL", 0);
	Счётчики.Вставить("АДРЕС", 0);
	Счётчики.Вставить("ФИО", 0);
	Счётчики.Вставить("РС", 0);
	Счётчики.Вставить("БИК", 0);
	Счётчики.Вставить("ПАСПОРТ", 0);
	Счётчики.Вставить("СНИЛС", 0);
	
	// Загружаем данные из базы для токенизации (с кэшированием)
	ДанныеДляТокенизации = ПолучитьКэшДанныхТокенизации();
	
	// 1. Токенизируем контрагентов (наименования из базы, отсортированы по длине убыв)
	Для Каждого Контрагент Из ДанныеДляТокенизации.Контрагенты Цикл
		Если СтрНайти(ТекущийТекст, Контрагент.Наименование) > 0 Тогда
			Счётчики.КОНТР = Счётчики.КОНТР + 1;
			Токен = "[КОНТР_" + Формат(Счётчики.КОНТР, "ЧГ=0") + "]";
			Маппинг.Вставить(Токен, Контрагент.Наименование);
			ТекущийТекст = СтрЗаменить(ТекущийТекст, Контрагент.Наименование, Токен);
		КонецЕсли;
	КонецЦикла;
	
	// 2. Токенизируем физлиц/сотрудников (ФИО из базы, отсортированы по длине убыв)
	Для Каждого ФизЛицо Из ДанныеДляТокенизации.ФизЛица Цикл
		Если СтрНайти(ТекущийТекст, ФизЛицо.ФИО) > 0 Тогда
			Счётчики.ФИО = Счётчики.ФИО + 1;
			Токен = "[ФИО_" + Формат(Счётчики.ФИО, "ЧГ=0") + "]";
			Маппинг.Вставить(Токен, ФизЛицо.ФИО);
			ТекущийТекст = СтрЗаменить(ТекущийТекст, ФизЛицо.ФИО, Токен);
		КонецЕсли;
	КонецЦикла;
	
	// 3. Токенизируем адреса (из базы, отсортированы по длине убыв)
	Для Каждого Адрес Из ДанныеДляТокенизации.Адреса Цикл
		Если СтрНайти(ТекущийТекст, Адрес.Представление) > 0 Тогда
			Счётчики.АДРЕС = Счётчики.АДРЕС + 1;
			Токен = "[АДРЕС_" + Формат(Счётчики.АДРЕС, "ЧГ=0") + "]";
			Маппинг.Вставить(Токен, Адрес.Представление);
			ТекущийТекст = СтрЗаменить(ТекущийТекст, Адрес.Представление, Токен);
		КонецЕсли;
	КонецЦикла;
	
	// 4. Токенизируем ИНН (паттерн 10-12 цифр)
	ТекущийТекст = ТокенизироватьПоПаттерну(ТекущийТекст, "ИНН", 10, 12, Счётчики, Маппинг);
	
	// 5. Токенизируем КПП (9 цифр)
	ТекущийТекст = ТокенизироватьПоПаттерну(ТекущийТекст, "КПП", 9, 9, Счётчики, Маппинг);
	
	// 6. Токенизируем ОГРН (13-15 цифр)
	ТекущийТекст = ТокенизироватьПоПаттерну(ТекущийТекст, "ОГРН", 13, 15, Счётчики, Маппинг);
	
	// 7. Токенизируем телефоны
	ТекущийТекст = ТокенизироватьТелефоны(ТекущийТекст, Счётчики, Маппинг);
	
	// 8. Токенизируем email
	ТекущийТекст = ТокенизироватьEmail(ТекущийТекст, Счётчики, Маппинг);
	
	// 9. Токенизируем банковские реквизиты
	ТекущийТекст = ТокенизироватьПоПаттерну(ТекущийТекст, "РС", 20, 20, Счётчики, Маппинг);
	ТекущийТекст = ТокенизироватьПоПаттерну(ТекущийТекст, "БИК", 9, 9, Счётчики, Маппинг);
	
	// 10. Токенизируем СНИЛС
	ТекущийТекст = ТокенизироватьПоПаттерну(ТекущийТекст, "СНИЛС", 11, 14, Счётчики, Маппинг);
	
	// Сохраняем маппинг в диалог для последующей детокенизации
	Если СсылкаДиалога <> Неопределено И ЗначениеЗаполнено(СсылкаДиалога) Тогда
		СохранитьМаппингВДиалог(СсылкаДиалога, Маппинг);
	КонецЕсли;
	
	Результат.ТокенизированныйТекст = ТекущийТекст;
	Результат.Маппинг = Маппинг;
	
	Возврат Результат;
	
КонецФункции

// Восстанавливает исходные данные из токенов в тексте
//
// Параметры:
//  Текст - Строка - текст с токенами
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог для получения маппинга
//  Маппинг - Соответствие - (опционально) маппинг токен -> значение, если не указан - берётся из диалога
//
// Возвращаемое значение:
//  Строка - текст с восстановленными данными
//
Функция ДетокенизироватьТекст(Знач Текст, СсылкаДиалога = Неопределено, Маппинг = Неопределено) Экспорт
	
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	
	// Получаем маппинг
	ИспользуемыйМаппинг = Маппинг;
	Если ИспользуемыйМаппинг = Неопределено И СсылкаДиалога <> Неопределено Тогда
		ИспользуемыйМаппинг = ЗагрузитьМаппингИзДиалога(СсылкаДиалога);
	КонецЕсли;
	
	Если ИспользуемыйМаппинг = Неопределено Тогда
		Возврат Текст;
	КонецЕсли;
	
	Результат = Текст;
	
	// Заменяем все токены обратно на исходные значения
	Для Каждого КлючЗначение Из ИспользуемыйМаппинг Цикл
		Результат = СтрЗаменить(Результат, КлючЗначение.Ключ, КлючЗначение.Значение);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает признак включённой анонимизации.
// Анонимизация считается включённой, если не отключена явно (зарезервировано для будущих настроек).
//
// Возвращаемое значение:
//  Булево - Истина, если анонимизация включена
//
Функция АнонимизацияВключена() Экспорт
	Возврат Истина;
КонецФункции

// Загружает данные из базы для токенизации (контрагенты, физлица, адреса)
//
// Возвращаемое значение:
//  Структура:
//    Контрагенты - Массив структур с полем Наименование
//    ФизЛица - Массив структур с полем ФИО
//    Адреса - Массив структур с полем Представление
//
Функция ЗагрузитьДанныеДляТокенизации() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Контрагенты", Новый Массив);
	Результат.Вставить("ФизЛица", Новый Массив);
	Результат.Вставить("Адреса", Новый Массив);
	
	// Загружаем контрагентов (до 1000, сортировка по длине убыв для корректной замены)
	Попытка
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1000
			|	Контрагенты.Наименование КАК Наименование
			|ИЗ
			|	Справочник.Контрагенты КАК Контрагенты
			|ГДЕ
			|	НЕ Контрагенты.ПометкаУдаления
			|	И Контрагенты.Наименование <> """"
			|УПОРЯДОЧИТЬ ПО
			|	ДЛИНА(Контрагенты.Наименование) УБЫВ";
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Результат.Контрагенты.Добавить(Новый Структура("Наименование", СокрЛП(Выборка.Наименование)));
		КонецЦикла;
	Исключение
		// Справочник Контрагенты может отсутствовать в конфигурации
	КонецПопытки;
	
	// Загружаем физлиц (до 1000, сортировка по длине убыв)
	Попытка
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1000
			|	ФизическиеЛица.Наименование КАК ФИО
			|ИЗ
			|	Справочник.ФизическиеЛица КАК ФизическиеЛица
			|ГДЕ
			|	НЕ ФизическиеЛица.ПометкаУдаления
			|	И ФизическиеЛица.Наименование <> """"
			|УПОРЯДОЧИТЬ ПО
			|	ДЛИНА(ФизическиеЛица.Наименование) УБЫВ";
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Результат.ФизЛица.Добавить(Новый Структура("ФИО", СокрЛП(Выборка.ФИО)));
		КонецЦикла;
	Исключение
		// Справочник ФизическиеЛица может отсутствовать
	КонецПопытки;
	
	// Пробуем загрузить сотрудников (альтернативный справочник)
	Попытка
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 500
			|	Сотрудники.Наименование КАК ФИО
			|ИЗ
			|	Справочник.Сотрудники КАК Сотрудники
			|ГДЕ
			|	НЕ Сотрудники.ПометкаУдаления
			|	И Сотрудники.Наименование <> """"
			|УПОРЯДОЧИТЬ ПО
			|	ДЛИНА(Сотрудники.Наименование) УБЫВ";
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Результат.ФизЛица.Добавить(Новый Структура("ФИО", СокрЛП(Выборка.ФИО)));
		КонецЦикла;
	Исключение
		// Справочник Сотрудники может отсутствовать
	КонецПопытки;
	
	// Адреса из регистра контактной информации
	Попытка
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 500
			|	КонтактнаяИнформация.Представление КАК Представление
			|ИЗ
			|	РегистрСведений.КонтактнаяИнформация КАК КонтактнаяИнформация
			|ГДЕ
			|	КонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
			|	И КонтактнаяИнформация.Представление <> """"
			|УПОРЯДОЧИТЬ ПО
			|	ДЛИНА(КонтактнаяИнформация.Представление) УБЫВ";
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Результат.Адреса.Добавить(Новый Структура("Представление", СокрЛП(Выборка.Представление)));
		КонецЦикла;
	Исключение
		// Регистр КонтактнаяИнформация может отсутствовать
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращает кэшированные данные для токенизации.
// Кэш хранится в параметрах сеанса на время текущего сеанса.
Функция ПолучитьКэшДанныхТокенизации()
	
	КэшДанных = Неопределено;
	
	Попытка
		Если ПараметрыСеанса.Свойство("ИИА_КэшТокенизации") Тогда
			КэшДанных = ПараметрыСеанса.ИИА_КэшТокенизации;
		КонецЕсли;
	Исключение
		// Параметры сеанса могут быть недоступны
	КонецПопытки;
	
	Если КэшДанных <> Неопределено Тогда
		Возврат КэшДанных;
	КонецЕсли;
	
	// Загружаем данные и сохраняем в кэш
	КэшДанных = ЗагрузитьДанныеДляТокенизации();
	
	Попытка
		ПараметрыСеанса.ИИА_КэшТокенизации = КэшДанных;
	Исключение
		// Параметр сеанса не зарегистрирован — работаем без кэша
	КонецПопытки;
	
	Возврат КэшДанных;
	
КонецФункции

// Сохраняет маппинг токенов в данные диалога
Процедура СохранитьМаппингВДиалог(СсылкаДиалога, Маппинг)
	
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		// Получаем текущие данные диалога
		СтруктураДанных = ИИА_Сервер.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
		Если СтруктураДанных = Неопределено Тогда
			СтруктураДанных = Новый Структура;
		КонецЕсли;
		
		// Получаем существующий маппинг или создаём новый
		СуществующийМаппинг = Неопределено;
		Если СтруктураДанных.Свойство("ТокенМаппинг") Тогда
			СуществующийМаппинг = СтруктураДанных.ТокенМаппинг;
		КонецЕсли;
		
		Если СуществующийМаппинг = Неопределено Тогда
			СуществующийМаппинг = Новый Соответствие;
		КонецЕсли;
		
		// Добавляем новые токены к существующим
		Для Каждого КлючЗначение Из Маппинг Цикл
			СуществующийМаппинг.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
		КонецЦикла;
		
		СтруктураДанных.Вставить("ТокенМаппинг", СуществующийМаппинг);
		
		// Сохраняем обратно
		ИИА_Сервер.СохранитьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
		
	Исключение
		// Логируем ошибку, но не прерываем работу
		ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога,
			"[TOKENIZE_ERROR] Ошибка сохранения маппинга: " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

// Загружает маппинг токенов из данных диалога
Функция ЗагрузитьМаппингИзДиалога(СсылкаДиалога)
	
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		СтруктураДанных = ИИА_Сервер.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
		Если СтруктураДанных <> Неопределено И СтруктураДанных.Свойство("ТокенМаппинг") Тогда
			Возврат СтруктураДанных.ТокенМаппинг;
		КонецЕсли;
	Исключение
		// Ошибка загрузки
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции

// Токенизирует числовые паттерны (ИНН, КПП, ОГРН и т.д.) по ключевым словам
Функция ТокенизироватьПоПаттерну(Знач Текст, ТипТокена, МинДлина, МаксДлина, Счётчики, Маппинг)
	
	Результат = Текст;
	КлючевыеСлова = ПолучитьКлючевыеСловаДляТипа(ТипТокена);
	
	Для Каждого КлючевоеСлово Из КлючевыеСлова Цикл
		
		Позиция = СтрНайти(ВРег(Результат), ВРег(КлючевоеСлово));
		Пока Позиция > 0 Цикл
			
			// Ищем числовую последовательность после ключевого слова
			НачалоПоиска = Позиция + СтрДлина(КлючевоеСлово);
			НайденноеЗначение = ИзвлечьЧисловуюПоследовательность(Результат, НачалоПоиска, МинДлина, МаксДлина);
			
			Если НайденноеЗначение.Найдено Тогда
				// Создаём токен
				Счётчики[ТипТокена] = Счётчики[ТипТокена] + 1;
				Токен = "[" + ТипТокена + "_" + Формат(Счётчики[ТипТокена], "ЧГ=0") + "]";
				
				// Сохраняем маппинг
				Маппинг.Вставить(Токен, НайденноеЗначение.Значение);
				
				// Заменяем в тексте
				Результат = Лев(Результат, НайденноеЗначение.НачалоПозиции - 1)
					+ Токен
					+ Сред(Результат, НайденноеЗначение.КонецПозиции + 1);
			КонецЕсли;
			
			СледующаяПозиция = СтрНайти(ВРег(Результат), ВРег(КлючевоеСлово), , Позиция + 1);
			Если СледующаяПозиция = 0 ИЛИ СледующаяПозиция <= Позиция Тогда
				Прервать;
			КонецЕсли;
			Позиция = СледующаяПозиция;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьКлючевыеСловаДляТипа(ТипТокена)
	
	Результат = Новый Массив;
	
	Если ТипТокена = "ИНН" Тогда
		Результат.Добавить("ИНН");
		Результат.Добавить("инн");
	ИначеЕсли ТипТокена = "КПП" Тогда
		Результат.Добавить("КПП");
		Результат.Добавить("кпп");
	ИначеЕсли ТипТокена = "ОГРН" Тогда
		Результат.Добавить("ОГРН");
		Результат.Добавить("ОГРНИП");
		Результат.Добавить("огрн");
	ИначеЕсли ТипТокена = "РС" Тогда
		Результат.Добавить("Р/С");
		Результат.Добавить("р/с");
		Результат.Добавить("Расч");
		Результат.Добавить("расч");
		Результат.Добавить("К/С");
		Результат.Добавить("к/с");
		Результат.Добавить("Корр");
	ИначеЕсли ТипТокена = "БИК" Тогда
		Результат.Добавить("БИК");
		Результат.Добавить("бик");
	ИначеЕсли ТипТокена = "СНИЛС" Тогда
		Результат.Добавить("СНИЛС");
		Результат.Добавить("снилс");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИзвлечьЧисловуюПоследовательность(Текст, НачалоПоиска, МинДлина, МаксДлина)
	
	Результат = Новый Структура;
	Результат.Вставить("Найдено", Ложь);
	Результат.Вставить("Значение", "");
	Результат.Вставить("НачалоПозиции", 0);
	Результат.Вставить("КонецПозиции", 0);
	
	// Пропускаем разделители перед числом
	НачалоЧисел = 0;
	Для Индекс = НачалоПоиска По Мин(НачалоПоиска + 10, СтрДлина(Текст)) Цикл
		Символ = Сред(Текст, Индекс, 1);
		Если ЭтоЦифра(Символ) Тогда
			НачалоЧисел = Индекс;
			Прервать;
		ИначеЕсли НЕ (Символ = " " ИЛИ Символ = ":" ИЛИ Символ = "	" ИЛИ Символ = "-") Тогда
			Возврат Результат;
		КонецЕсли;
	КонецЦикла;
	
	Если НачалоЧисел = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	// Собираем числовую последовательность (цифры и разделители)
	КонецЧисел = НачалоЧисел;
	Значение = "";
	КоличествоЦифр = 0;
	
	Для Индекс = НачалоЧисел По СтрДлина(Текст) Цикл
		Символ = Сред(Текст, Индекс, 1);
		Если ЭтоЦифра(Символ) Тогда
			КоличествоЦифр = КоличествоЦифр + 1;
			Значение = Значение + Символ;
			КонецЧисел = Индекс;
		ИначеЕсли Символ = "-" ИЛИ Символ = " " Тогда
			Значение = Значение + Символ;
			КонецЧисел = Индекс;
		Иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если КоличествоЦифр >= МинДлина И КоличествоЦифр <= МаксДлина Тогда
		Результат.Найдено = Истина;
		Результат.Значение = СокрЛП(Значение);
		Результат.НачалоПозиции = НачалоЧисел;
		Результат.КонецПозиции = КонецЧисел;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Токенизирует телефонные номера в формате +7... или 8(...)
Функция ТокенизироватьТелефоны(Знач Текст, Счётчики, Маппинг)
	
	Результат = Текст;
	Позиция = 1;
	
	Пока Позиция <= СтрДлина(Результат) Цикл
		
		// Ищем начало телефона
		ПозицияПлюс = СтрНайти(Результат, "+7", , Позиция);
		ПозицияВосемь = СтрНайти(Результат, "8(", , Позиция);
		Если ПозицияВосемь = 0 Тогда
			ПозицияВосемь = СтрНайти(Результат, "8 (", , Позиция);
		КонецЕсли;
		
		НачалоТелефона = 0;
		Если ПозицияПлюс > 0 И (ПозицияВосемь = 0 ИЛИ ПозицияПлюс < ПозицияВосемь) Тогда
			НачалоТелефона = ПозицияПлюс;
		ИначеЕсли ПозицияВосемь > 0 Тогда
			НачалоТелефона = ПозицияВосемь;
		Иначе
			Прервать;
		КонецЕсли;
		
		// Извлекаем телефон
		КоличествоЦифр = 0;
		КонецТелефона = НачалоТелефона;
		ТекстТелефона = "";
		
		Для Индекс = НачалоТелефона По Мин(НачалоТелефона + 20, СтрДлина(Результат)) Цикл
			Символ = Сред(Результат, Индекс, 1);
			Если ЭтоЦифра(Символ) ИЛИ Символ = "+" ИЛИ Символ = "(" ИЛИ Символ = ")" ИЛИ Символ = "-" ИЛИ Символ = " " Тогда
				Если ЭтоЦифра(Символ) Тогда
					КоличествоЦифр = КоличествоЦифр + 1;
				КонецЕсли;
				ТекстТелефона = ТекстТелефона + Символ;
				КонецТелефона = Индекс;
			Иначе
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если КоличествоЦифр >= 10 Тогда
			Счётчики.ТЕЛ = Счётчики.ТЕЛ + 1;
			Токен = "[ТЕЛ_" + Формат(Счётчики.ТЕЛ, "ЧГ=0") + "]";
			Маппинг.Вставить(Токен, СокрЛП(ТекстТелефона));
			Результат = Лев(Результат, НачалоТелефона - 1) + Токен + Сред(Результат, КонецТелефона + 1);
			Позиция = НачалоТелефона + СтрДлина(Токен);
		Иначе
			Позиция = НачалоТелефона + 1;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Токенизирует адреса электронной почты
Функция ТокенизироватьEmail(Знач Текст, Счётчики, Маппинг)
	
	Результат = Текст;
	Позиция = 1;
	
	Пока Позиция <= СтрДлина(Результат) Цикл
		
		ПозицияСобаки = СтрНайти(Результат, "@", , Позиция);
		Если ПозицияСобаки = 0 Тогда
			Прервать;
		КонецЕсли;
		
		// Ищем начало email (символы слева от @)
		НачалоEmail = ПозицияСобаки;
		Пока НачалоEmail > 1 Цикл
			Символ = Сред(Результат, НачалоEmail - 1, 1);
			Если НЕ ЭтоСимволEmail(Символ) Тогда
				Прервать;
			КонецЕсли;
			НачалоEmail = НачалоEmail - 1;
		КонецЦикла;
		
		// Ищем конец email (символы справа от @)
		КонецEmail = ПозицияСобаки;
		Пока КонецEmail < СтрДлина(Результат) Цикл
			Символ = Сред(Результат, КонецEmail + 1, 1);
			Если НЕ ЭтоСимволEmail(Символ) И Символ <> "." Тогда
				Прервать;
			КонецЕсли;
			КонецEmail = КонецEmail + 1;
		КонецЦикла;
		
		Если КонецEmail > ПозицияСобаки И НачалоEmail < ПозицияСобаки Тогда
			ИсходныйEmail = Сред(Результат, НачалоEmail, КонецEmail - НачалоEmail + 1);
			Если СтрДлина(ИсходныйEmail) >= 5 Тогда
				Счётчики.EMAIL = Счётчики.EMAIL + 1;
				Токен = "[EMAIL_" + Формат(Счётчики.EMAIL, "ЧГ=0") + "]";
				Маппинг.Вставить(Токен, ИсходныйEmail);
				Результат = Лев(Результат, НачалоEmail - 1) + Токен + Сред(Результат, КонецEmail + 1);
				Позиция = НачалоEmail + СтрДлина(Токен);
			Иначе
				Позиция = ПозицияСобаки + 1;
			КонецЕсли;
		Иначе
			Позиция = ПозицияСобаки + 1;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЭтоЦифра(Символ)
	Возврат Символ >= "0" И Символ <= "9";
КонецФункции

Функция ЭтоСимволEmail(Символ)
	Возврат (Символ >= "a" И Символ <= "z")
		ИЛИ (Символ >= "A" И Символ <= "Z")
		ИЛИ (Символ >= "0" И Символ <= "9")
		ИЛИ Символ = "_"
		ИЛИ Символ = "-"
		ИЛИ Символ = ".";
КонецФункции

#КонецОбласти
