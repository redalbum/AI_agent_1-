		КонецЕсли;
		
		// CreateReference/SetField запрещены в Запрос1С
		DSLИзменение = "{""steps"":[{""action"":""CreateReference"",""object_name"":""Контрагенты""},{""action"":""SetField"",""field_name"":""Наименование"",""value"":""X""}]}";
