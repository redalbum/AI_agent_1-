Функция ТестКонтрактAntiGiveup() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		Реестр = ИИА_Оркестратор.ПолучитьРеестрПолитикВосстановления();
		ПолитикаПараметров = Реестр.Получить("parameter_missing");
		ПолитикаSafety = Реестр.Получить("query_safety_violation");
		ПолитикаExecution = Реестр.Получить("query_execution_error");
		Если ПолитикаПараметров = Неопределено Тогда
			Результат.Сообщение = "Отсутствует anti-giveup policy для parameter_missing";
			Возврат Результат;
		КонецЕсли;
		Если ПолитикаSafety = Неопределено Тогда
			Результат.Сообщение = "Отсутствует anti-giveup policy для query_safety_violation";
			Возврат Результат;
		КонецЕсли;
		Если ПолитикаExecution = Неопределено Тогда
			Результат.Сообщение = "Отсутствует anti-giveup policy для query_execution_error";
			Возврат Результат;
		КонецЕсли;
		
		Промпт = ИИА_Промты.ПолучитьПромптPlannerСледующегоШага("[{""Задача"":""RunQuery{query:'ВЫБРАТЬ ...'}""}]", "Ошибка: field_not_found", "Период, Сумма", "");
		Если СтрНайти(ВРег(Промпт), "ANTI-GIVEUP") = 0 Тогда
			Результат.Сообщение = "Промпт Planner должен содержать anti-giveup правило";
			Возврат Результат;
		КонецЕсли;
		ПромптРемонта = ИИА_Промты.ПолучитьПромптИсправленияDSL("query_execution_error", "{""dsl_version"":2,""steps"":[{""action"":""RunQuery"",""query"":""ВЫБРАТЬ ...""}]}", "");
		Если СтрНайти(ВРег(ПромптРемонта), "ПРЕДЫДУЩИЙ") = 0 Тогда
			Результат.Сообщение = "Промпт исправления должен запрещать ПРЕДЫДУЩИЙ и нестабильные конструкции";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: anti-giveup контракт настроен";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестAntiGiveupБлокРаннегоShowInfo() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Запрос1С);
		ИИА_Сервер.ИнициализироватьКонтекстАрхитектуры(СсылкаДиалога);
		
		ОшибкаExecutor = Новый Структура("Успех,Сообщение,error_code", Ложь, "field_not_found", "field_not_found");
		ИИА_Сервер.СохранитьРезультатExecutor(СсылкаДиалога, ОшибкаExecutor);
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Recover", "test_attempt_1", Истина);
		
		DSLСдача = "{""dsl_version"":2,""steps"":[{""action"":""ShowInfo"",""message"":""Нет: задача не выполнена""}]}";
		ИИА_Сервер.СохранитьАртефактПланировщика(СсылкаДиалога, DSLСдача, "test", "1");
		
		УспехExecute = ИИА_Оркестратор.ВыполнитьСтадиюExecute(СсылкаДиалога);
		Если УспехExecute Тогда
			Результат.Сообщение = "Execute должен блокировать раннюю сдачу ShowInfo";
			Возврат Результат;
		КонецЕсли;
		
		РезультатExecutor = ИИА_Сервер.ПолучитьРезультатExecutor(СсылкаДиалога);
		Если РезультатExecutor = Неопределено Или НЕ РезультатExecutor.Свойство("error_code") Тогда
			Результат.Сообщение = "После блокировки должен быть сохранен результат с error_code";
			Возврат Результат;
		КонецЕсли;
		Если ВРег(Строка(РезультатExecutor.error_code)) <> "PREMATURE_GIVEUP_BLOCKED" Тогда
			Результат.Сообщение = "Ожидается error_code=premature_giveup_blocked";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: ранний ShowInfo блокируется";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

