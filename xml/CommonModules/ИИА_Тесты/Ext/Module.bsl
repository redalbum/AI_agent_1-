	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Запрос1С);
		ИИА_Сервер.ИнициализироватьКонтекстАрхитектуры(СсылкаДиалога);
		
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Recover", "attempt_1", Истина);
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Recover", "attempt_2", Истина);
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Recover", "attempt_3", Истина);
		
		ОшибкаExecutor = Новый Структура("Успех,Сообщение,error_code", Ложь, "field_not_found", "field_not_found");
		ИИА_Сервер.СохранитьРезультатExecutor(СсылкаДиалога, ОшибкаExecutor);
		
		РезультатValidate = ИИА_Оркестратор.ВыполнитьСтадиюValidate(СсылкаДиалога);
		Если РезультатValidate = Неопределено Или НЕ РезультатValidate.Свойство("СледующаяСтадия") Тогда
			Результат.Сообщение = "Validate должен вернуть следующую стадию";
			Возврат Результат;
		КонецЕсли;
		Если РезультатValidate.СледующаяСтадия <> "Summarize" Тогда
			Результат.Сообщение = "При исчерпании recovery должен быть переход в Summarize";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: recovery_exhausted корректно ведет в summary";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестНормализацииStepFailedВRecoverable() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		Executor = Новый Структура("Успех,Сообщение,error_code", Ложь, "Ошибка выполнения шага 'RunQuery': Поле не найдено ""Документ.РасходнаяНакладная.Сумма""", "step_failed");
		Код = ИИА_Оркестратор.ИзвлечьКодОшибки(Executor);
		Если Код <> "field_not_found" Тогда
			Результат.Сообщение = "step_failed должен нормализоваться в field_not_found для recovery-policy";
			Результат.Детали.Добавить("Фактический код: " + Строка(Код));
			Возврат Результат;
		КонецЕсли;
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: step_failed нормализуется в recoverable-код";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестQuerySafetyGateВложенныеПоля() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		DSLВалидный =
			"{""dsl_version"":2,""steps"":[" +
			"{""action"":""GetObjectFields"",""object_type"":""Документ"",""object_name"":""РасходнаяНакладная""}," +
			"{""action"":""RunQuery"",""query"":""ВЫБРАТЬ ПЕРВЫЕ 1 РасходнаяНакладная.Контрагент.Наименование КАК Контрагент ИЗ Документ.РасходнаяНакладная КАК РасходнаяНакладная""}" +
			"]}";
		РезультатВалидный = ИИА_DSL.ВыполнитьDSL(DSLВалидный);
		Если НЕ РезультатВалидный.Свойство("СистемныйОтвет") Тогда
			Результат.Сообщение = "Отсутствует системный ответ для проверки вложенного валидного пути";
			Возврат Результат;
		КонецЕсли;
		Если СтрНайти(ВРег(РезультатВалидный.СистемныйОтвет), "QUERY_SAFETY_VIOLATION") > 0 Тогда
			Результат.Сообщение = "Валидный nested-path Контрагент.Наименование не должен блокироваться safety gate";
			Результат.Детали.Добавить(Лев(РезультатВалидный.СистемныйОтвет, 800));
			Возврат Результат;
		КонецЕсли;
		
		DSLНевалидный =
			"{""dsl_version"":2,""steps"":[" +
			"{""action"":""GetObjectFields"",""object_type"":""Документ"",""object_name"":""РасходнаяНакладная""}," +
			"{""action"":""RunQuery"",""query"":""ВЫБРАТЬ ПЕРВЫЕ 1 РасходнаяНакладная.Контрагент.НесуществующееПоле КАК Х ИЗ Документ.РасходнаяНакладная КАК РасходнаяНакладная""}" +
			"]}";
		РезультатНевалидный = ИИА_DSL.ВыполнитьDSL(DSLНевалидный);
		Если НЕ РезультатНевалидный.Свойство("СистемныйОтвет") Тогда
			Результат.Сообщение = "Отсутствует системный ответ для проверки вложенного невалидного пути";
			Возврат Результат;
		КонецЕсли;
		Если СтрНайти(ВРег(РезультатНевалидный.СистемныйОтвет), "QUERY_SAFETY_VIOLATION") = 0 Тогда
			Результат.Сообщение = "Невалидный nested-path должен блокироваться Query Safety Gate";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: nested-path в Query Safety Gate валидируется по whitelist_paths";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

